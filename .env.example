# Server-only OpenAI configuration. Never prefix these variables with NEXT_PUBLIC_.
# For Vercel Preview, leave all four values unset to keep deterministic fallback mode.
# Configure Production only after shared rate limiting or equivalent edge protection is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Use a stable random value of at least 32 bytes in Production to authorize exact-caption speech requests.
# Generate one locally with: openssl rand -base64 48 | tr -d '\n'
SPEECH_AUTHORIZATION_SECRET=
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
