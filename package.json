{
  "name": "history-unbroken",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.18.0 <23",
    "npm": ">=10.5.1"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --workers=4",
    "test:deployed": "playwright test --config=playwright.deployed.config.ts",
    "test:live:openai": "playwright test --config=playwright.live.config.ts",
    "test:performance": "HISTORY_UNBROKEN_PERFORMANCE=1 playwright test tests/e2e/world-performance.spec.ts --workers=1",
    "capture:screenshots": "playwright test --config=playwright.capture.config.ts",
    "verify:release": "node scripts/verify-release.mjs"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/rapier": "2.2.0",
    "ecctrl": "2.0.0",
    "lucide-react": "^0.468.0",
    "music-metadata": "^11.14.0",
    "next": "^16.2.10",
    "openai": "^6.47.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "0.185.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^27.2.0",
    "sharp": "0.34.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
